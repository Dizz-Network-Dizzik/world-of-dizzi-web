/*
  Content-Security-Policy: default-src 'none'; img-src 'self' data:; style-src 'self'; font-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin

# The site itself ships no JavaScript at all, so `default-src 'none'` already
# closes script execution and no script-src line is needed.

/karte/*
  Content-Security-Policy: default-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:*; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY

# The system map is a byte-identical copy of _netzwerk/SYSTEM_KARTE.html from the
# public repository. It is self-contained but carries inline style and script,
# so the relaxation is scoped to this one path and nowhere else. Its optional
# health watch probes http://127.0.0.1:8200 and falls back to the offline view
# when nothing answers - which, on a public host, is always.

/schrift/*
  Cache-Control: public, max-age=31536000, immutable

/bilder/*
  Cache-Control: public, max-age=604800
